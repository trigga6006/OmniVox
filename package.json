{
  "name": "omnivoice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:sidecar": "cargo build --manifest-path src-tauri/llm-sidecar/Cargo.toml && cp src-tauri/llm-sidecar/target/debug/omnivox-llm.exe src-tauri/target/debug/omnivox-llm.exe",
    "build:sidecar:release": "cargo build --release --manifest-path src-tauri/llm-sidecar/Cargo.toml && cp src-tauri/llm-sidecar/target/release/omnivox-llm.exe src-tauri/target/release/omnivox-llm.exe",
    "tauri:dev": "npm run build:sidecar && tauri dev --features llm",
    "tauri:build": "npm run build:sidecar:release && tauri build --features llm"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "lucide-react": "^0.468",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3",
    "tw-animate-css": "^1",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6",
    "@tauri-apps/cli": "^2"
  }
}
